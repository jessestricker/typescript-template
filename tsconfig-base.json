{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "module": "node20",
    "target": "es2024",
    "types": [], // TODO: remove once using TypeScript 6.0

    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": true, // TODO: remove once using TypeScript 6.0
    "moduleDetection": "force"
  }
}
